{
  "name": "@thatscalaguy/gpgpu.js",
  "version": "0.1.0",
  "description": "User-friendly GPGPU computing in JavaScript using WebGPU",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gpu",
    "gpgpu",
    "webgpu",
    "compute",
    "parallel",
    "wgsl"
  ],
  "author": "Sven Herrmann <sven.herrmann@thatscalaguy.de>",
  "license": "MIT",
  "homepage": "https://github.com/ThatScalaGuy/GPGPU.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThatScalaGuy/GPGPU.js.git"
  },
  "bugs": {
    "url": "https://github.com/ThatScalaGuy/GPGPU.js/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
